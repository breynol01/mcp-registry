{
  "name": "mcp-registry",
  "version": "0.1.0",
  "description": "Canonical MCP server registry — tool-agnostic discovery and management of Model Context Protocol servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-registry": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "registry"
  ],
  "license": "MIT",
  "dependencies": {
